---
/**
 * "As featured in" press strip for the home page. Pulls the outlets straight
 * from the media collection, so it stays in sync as you add appearances.
 */
import { getCollection } from "astro:content";

const items = (await getCollection("media", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Unique outlet names, most recent first.
const outlets = [...new Set(items.map((i) => i.data.outlet))];
---

{
  outlets.length > 0 && (
    <a href="/media/" class="reveal block rule py-8 no-underline group">
      <p class="label mb-5 text-center">As featured in</p>
      <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-center">
        {outlets.map((outlet) => (
          <li class="font-serif text-base text-ink/70 transition-colors group-hover:text-ink sm:text-lg">
            {outlet}
          </li>
        ))}
      </ul>
    </a>
  )
}
