---
import { formatDate } from "@/utils/format";

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  pillar?: string;
  readingTime?: string;
}
const { href, title, description, date, pillar, readingTime } = Astro.props;
---

<article class="reveal group border-t border-hairline py-8 first:border-t-0">
  <a href={href} class="block no-underline">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
      <time class="label" datetime={date.toISOString()}>{formatDate(date)}</time
      >
      {pillar && <span class="label text-forest">{pillar}</span>}
      {readingTime && <span class="label">{readingTime}</span>}
    </div>
    <h3
      class="mt-3 text-2xl text-ink transition-colors group-hover:text-forest sm:text-[1.75rem]"
    >
      {title}
    </h3>
    <p class="mt-2 max-w-2xl leading-relaxed text-stone">{description}</p>
    <span
      class="mt-4 inline-flex items-center gap-1 font-sans text-sm text-forest"
    >
      Read
      <span
        class="transition-transform group-hover:translate-x-0.5"
        aria-hidden="true">&rarr;</span
      >
    </span>
  </a>
</article>
