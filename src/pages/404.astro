---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" noindex>
  <section
    class="container-content flex min-h-[60vh] flex-col items-center justify-center py-24 text-center"
  >
    <p class="label mb-5">404</p>
    <h1 class="text-display-sm">This page wandered off.</h1>
    <p class="mt-5 max-w-md text-lg text-stone">
      The page you're looking for doesn't exist or has moved. Let's get you back
      on track.
    </p>
    <div class="mt-9 flex flex-wrap justify-center gap-4">
      <a
        href="/"
        class="rounded-full bg-forest px-6 py-3 font-sans text-sm text-parchment no-underline hover:text-parchment"
      >
        Back home
      </a>
      <a
        href="/writing/"
        class="rounded-full border border-hairline px-6 py-3 font-sans text-sm text-ink no-underline hover:border-ink hover:text-ink"
      >
        Read my writing
      </a>
    </div>
  </section>
</BaseLayout>
