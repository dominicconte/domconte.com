---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { site } from "@/config/site";

const channels = [
  { label: "LinkedIn", value: "Connect", href: site.socials.linkedin },
  { label: "X", value: "@dominic_conte", href: site.socials.x },
  { label: "GitHub", value: "Code", href: site.socials.github },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Dom Conte - for speaking invitations, collaborations, or questions about legal AI."
  path="/contact/"
>
  <PageHeader
    eyebrow="Contact"
    title="Get in touch."
    lead="Speaking invitations, collaborations, press, or a question about legal AI - the best way to reach me is by email."
  />

  <section class="container-content py-16">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_1fr] lg:gap-16">
      <!-- Email -->
      <div class="reveal">
        <p class="label mb-3">Email me</p>
        <a
          href={`mailto:${site.email}`}
          class="font-serif text-3xl text-ink no-underline hover:text-forest sm:text-4xl"
        >
          {site.email}
        </a>
        <p class="mt-6 max-w-md leading-relaxed text-stone">
          I read everything, and aim to reply within a few working days. If it's
          a speaking enquiry, a quick note on your audience and what you'd like
          them to take away is always helpful.
        </p>
        <a
          href={`mailto:${site.email}`}
          class="mt-8 inline-flex rounded-full bg-forest px-7 py-3 font-sans text-sm text-parchment no-underline transition-transform hover:-translate-y-0.5 hover:text-parchment"
        >
          Send an email
        </a>
      </div>

      <!-- Elsewhere -->
      <aside class="reveal">
        <p class="label mb-5">Or find me elsewhere</p>
        <ul class="space-y-5">
          {
            channels.map((c) => (
              <li class="border-t border-hairline pt-5 first:border-t-0 first:pt-0">
                <p class="label mb-1">{c.label}</p>
                <a
                  href={c.href}
                  rel="me noopener"
                  target="_blank"
                  class="text-lg"
                >
                  {c.value}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="mt-8 text-sm leading-relaxed text-stone">
          Based in {site.location}.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>
