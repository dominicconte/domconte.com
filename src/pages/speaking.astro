---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import CallToAction from "@/components/CallToAction.astro";

const topics = [
  {
    title: "Making AI adoption stick in law firms",
    body: "Why most pilots stall, and the unglamorous work that separates the ones that scale.",
  },
  {
    title: "Lawyer to founder",
    body: "What practising law taught me about building software that fee-earners actually use.",
  },
  {
    title: "Build vs buy for legal AI",
    body: "A practical decision framework for general counsel and managing partners.",
  },
  {
    title: "Innovation that changes behaviour",
    body: "Moving beyond innovation theatre to the things that genuinely shift how firms work.",
  },
];

const talks = [
  {
    event: "Legal Innovation Spotlight",
    role: "Podcast guest",
    year: "2025",
    note: "On what actually moves the needle on AI adoption inside law firms.",
  },
  {
    event: "King's College London Legal Tech Society",
    role: "Speaker",
    year: "2025",
    note: "Law + AI = Opportunity: how to position yourself for the future.",
  },
];
---

<BaseLayout
  title="Speaking"
  description="Dom Conte speaks on legal AI, adoption, and the lawyer-to-founder journey. Topics, past talks, and how to invite him to your event."
  path="/speaking/"
>
  <PageHeader
    eyebrow="Speaking"
    title="Talks on legal AI, adoption and change."
    lead="I speak to firms, conferences and teams about what it really takes to put AI to work in a regulated profession - candidly, and without the hype."
  />

  <!-- Topics -->
  <section class="container-content py-16">
    <h2 class="reveal text-2xl sm:text-3xl">Topics I speak on</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {
        topics.map((t) => (
          <div class="reveal rounded-lg border border-hairline bg-paper p-7">
            <h3 class="text-xl text-ink">{t.title}</h3>
            <p class="mt-2 leading-relaxed text-stone">{t.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Past talks -->
  <section class="container-content py-8">
    <h2 class="reveal text-2xl sm:text-3xl">Recent appearances</h2>
    <ul class="mt-8 max-w-3xl">
      {
        talks.map((talk) => (
          <li class="reveal flex flex-col gap-1 border-t border-hairline py-6 first:border-t-0 sm:flex-row sm:items-baseline sm:gap-6">
            <span class="label w-16 shrink-0">{talk.year}</span>
            <div>
              <p class="font-serif text-xl text-ink">{talk.event}</p>
              <p class="text-sm text-forest">{talk.role}</p>
              <p class="mt-1 text-stone">{talk.note}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <CallToAction
    title="Invite me to speak"
    body="Planning a conference, panel, or internal session on legal AI? Tell me about your audience and what you'd like them to leave with."
    primaryHref="/contact/"
    primaryLabel="Check availability"
    secondaryHref="/media/"
    secondaryLabel="See past media"
  />
</BaseLayout>
