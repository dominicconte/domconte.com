---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import ProjectCard from "@/components/ProjectCard.astro";

const projects = (
  await getCollection("projects", ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects"
  description="A portfolio of AI projects by Dom Conte - experiments and products built for the practice of law."
  path="/projects/"
>
  <PageHeader
    eyebrow="Projects"
    title="Things I'm building with AI."
    lead="A working portfolio of legal-AI experiments and products. Each one started from a real problem I watched lawyers struggle with."
  />

  <section class="container-content py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project) => (
          <ProjectCard
            href={`/projects/${project.slug}/`}
            title={project.data.title}
            summary={project.data.summary}
            tags={project.data.tags}
            year={project.data.year}
            status={project.data.status}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
